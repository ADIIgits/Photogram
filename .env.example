# Photogram Environment Variables

# The port the backend server will run on (default: 8080)
PORT=8080

# Environment mode (development or production)
NODE_ENV=development

# Secret key for sessions/JWT
SESSION_SECRET=photogram-dev-secret-change-me-in-production

# PostgreSQL Database Connection URL
# Example format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# If you run PostgreSQL locally via Homebrew or Docker, update this URL:
DATABASE_URL="postgresql://neondb_owner:npg_lbs2xDuHJ0in@ep-little-butterfly-amd28tbk.c-5.us-east-1.aws.neon.tech/neondb?sslmode=require"

# Optional Redis URL for caching (will fall back to database if not set)
