{
  "name": "@workspace/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "generate": "prisma generate --schema ./prisma/schema.prisma",
    "push": "prisma db push --schema ./prisma/schema.prisma --skip-generate",
    "push-force": "prisma db push --schema ./prisma/schema.prisma --skip-generate --accept-data-loss",
    "studio": "prisma studio --schema ./prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "pg": "^8.20.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/pg": "^8.20.0",
    "prisma": "^7.7.0"
  }
}
